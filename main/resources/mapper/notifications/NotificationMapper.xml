<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "../mybatis-3-mapper.dtd">
<mapper namespace="com.healthcare.feature.notifications.mapper.NotificationMapper">

    <resultMap id="userMap" type="com.healthcare.entity.User">
        <id property="id" column="u_id"/>
        <result property="name" column="u_name"/>
        <result property="mobileNumber" column="u_mobile_number"/>
        <result property="email" column="u_email"/>
        <result property="role" column="u_role"/>
        <result property="isActive" column="u_is_active"/>
        <result property="createdAt" column="u_created_at"/>
        <result property="updatedAt" column="u_updated_at"/>
    </resultMap>

    <resultMap id="notificationMap" type="com.healthcare.entity.Notification">
        <id property="id" column="n_id"/>
        <result property="title" column="n_title"/>
        <result property="message" column="n_message"/>
        <result property="type" column="n_type"/>
        <result property="isRead" column="n_is_read"/>
        <result property="createdAt" column="n_created_at"/>
        <association property="user" resultMap="userMap"/>
    </resultMap>

    <sql id="notificationSelectColumns">
        n.id AS n_id,
        n.title AS n_title,
        n.message AS n_message,
        n.type AS n_type,
        n.is_read AS n_is_read,
        n.created_at AS n_created_at,
        u.id AS u_id,
        u.name AS u_name,
        u.mobile_number AS u_mobile_number,
        u.email AS u_email,
        u.role AS u_role,
        u.is_active AS u_is_active,
        u.created_at AS u_created_at,
        u.updated_at AS u_updated_at
    </sql>

    <sql id="notificationBaseFrom">
        FROM notifications n
        JOIN users u ON u.id = n.user_id
    </sql>

    <select id="findById" resultMap="notificationMap">
        SELECT <include refid="notificationSelectColumns"/>
        <include refid="notificationBaseFrom"/>
        WHERE n.id = #{id}
    </select>

    <select id="findByUserIdOrderByCreatedAtDesc" resultMap="notificationMap">
        SELECT <include refid="notificationSelectColumns"/>
        <include refid="notificationBaseFrom"/>
        WHERE n.user_id = #{userId}
        ORDER BY n.created_at DESC, n.id DESC
    </select>

    <select id="findByUserIdAndIsReadFalse" resultMap="notificationMap">
        SELECT <include refid="notificationSelectColumns"/>
        <include refid="notificationBaseFrom"/>
        WHERE n.user_id = #{userId}
          AND n.is_read = FALSE
        ORDER BY n.created_at DESC, n.id DESC
    </select>

    <select id="countByUserIdAndIsReadFalse" resultType="long">
        SELECT COUNT(*)
        FROM notifications
        WHERE user_id = #{userId}
          AND is_read = FALSE
    </select>

    <insert id="insertNotification" parameterType="com.healthcare.entity.Notification" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO notifications (
            user_id,
            title,
            message,
            type,
            is_read,
            created_at
        ) VALUES (
            #{user.id},
            #{title},
            #{message},
            #{type},
            #{isRead},
            NOW(6)
        )
    </insert>

    <update id="updateNotification" parameterType="com.healthcare.entity.Notification">
        UPDATE notifications
        SET user_id = #{user.id},
            title = #{title},
            message = #{message},
            type = #{type},
            is_read = #{isRead}
        WHERE id = #{id}
    </update>

</mapper>
